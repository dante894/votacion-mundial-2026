# .htaccess — Seguridad y configuración Apache
# Compatible con: InfinityFree, 000webhost, ByetHost, AwardSpace

Options -Indexes

# Bloquear acceso directo a archivos sensibles
<FilesMatch "\.(sqlite|db|env|log|json|lock)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Proteger carpeta database
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^database/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^config/   - [F,L]
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Comprimir HTML/CSS/JS
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# PHP settings (si el host lo permite)
<IfModule mod_php.c>
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>
